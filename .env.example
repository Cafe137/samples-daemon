# Swarm gateway — used for both bee-js uploads and audio/manifest fetches
GATEWAY_URL=https://bzz.limo

# Private key for signing feed updates (hex, 0x prefix optional)
FEED_SIGNER_KEY=

# Feed topic string
FEED_TOPIC=

